# agentWorkBook Relay Server Configuration
# Copy this file to .env and update with your values

# API Keys (comma-separated, generate secure random keys for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEYS=dev-key-123,your-production-key-here

# Allowed Origins (comma-separated list of domains that can connect)
ALLOWED_ORIGINS=https://vishalmysore.github.io,http://localhost:3000,http://localhost:5173

# Server Port
PORT=8765

# Connection Limits
MAX_CONNECTIONS=500
MAX_CONNECTIONS_PER_IP=5

# Rate Limiting
RATE_LIMIT_WINDOW=1
RATE_LIMIT_MAX=100
